# aria-RPG environment variables — copy this to `.env` and fill in the values
# from your Render dashboard (Environment tab). Never commit the real .env.
#
#   cp .env.example .env   &&   nano .env

# ── REQUIRED — bot will not run without these ────────────────────────────────
# Database (Aiven MySQL) — same values as Render, no migration needed
DB_HOST=
DB_USER=
DB_PASS=
DB_NAME=
DB_PORT=16338

# WhatsApp / owner
BOT_PHONE_NUMBER=        # digits only, no + (used for pairing-code login)
OWNER_ID=                # your WhatsApp number, digits only
RAID_GROUP_JID=          # main dungeon group JID (…@g.us)

# AI (Aria personality) — whichever key your code uses
GROQ_API_KEY=

# ── OPTIONAL — features / extra group routing ────────────────────────────────
COMMUNITY_JID=           # parent community; auto-whitelists linked groups
TEST_GROUP_JID=          # tester sandbox group
CASINO_GC_JID=
PVP_GROUP_JID=
EXPLORATION_GC_JID=
EXPLORER_GC_JID=
GROUP_JID=               # fallback if RAID_GROUP_JID unset
PORT=3000                # Express dashboard port

# ── RENDER-ONLY — NOT needed on Oracle/VM (safe to omit) ─────────────────────
# RENDER_EXTERNAL_URL=   # was used for the self-ping keep-alive
# RENDER_API_KEY=
# RENDER_SERVICE_ID=
